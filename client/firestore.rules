rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isParticipant(chatId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
    }

    function connectionsOf(userData) {
      return userData.keys().hasAny(['connections']) ? userData.connections : [];
    }

    function connectedTo(peerId) {
      return peerId in connectionsOf(get(/databases/$(database)/documents/users/$(request.auth.uid)).data) ||
        request.auth.uid in connectionsOf(get(/databases/$(database)/documents/users/$(peerId)).data);
    }

    function directChatCanMessage(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId)).data;
      return chat.type != 'direct' ||
        (
          chat.participantIds.size() == 2 &&
          (
            (chat.participantIds[0] == request.auth.uid && connectedTo(chat.participantIds[1])) ||
            (chat.participantIds[1] == request.auth.uid && connectedTo(chat.participantIds[0]))
          )
        );
    }

    function onlyConnectionsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['connections']);
    }

    function acceptedConnectionRequest(userId) {
      return exists(/databases/$(database)/documents/connectionRequests/$(userId + '_' + request.auth.uid)) &&
        get(/databases/$(database)/documents/connectionRequests/$(userId + '_' + request.auth.uid)).data.senderId == userId &&
        get(/databases/$(database)/documents/connectionRequests/$(userId + '_' + request.auth.uid)).data.receiverId == request.auth.uid &&
        get(/databases/$(database)/documents/connectionRequests/$(userId + '_' + request.auth.uid)).data.status == 'accepted';
    }

    function canAddSelfToConnection(userId) {
      return request.auth.uid != userId &&
        onlyConnectionsChanged() &&
        !(request.auth.uid in connectionsOf(resource.data)) &&
        request.auth.uid in connectionsOf(request.resource.data) &&
        acceptedConnectionRequest(userId);
    }

    function canRemoveSelfFromConnection(userId) {
      return request.auth.uid != userId &&
        onlyConnectionsChanged() &&
        request.auth.uid in connectionsOf(resource.data) &&
        !(request.auth.uid in connectionsOf(request.resource.data));
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        request.auth.uid == userId ||
        canAddSelfToConnection(userId) ||
        canRemoveSelfFromConnection(userId)
      );

      match /blocked/{blockedUid} {
        allow read: if signedIn() && (
          request.auth.uid == userId ||
          request.auth.uid == blockedUid
        );
        allow write: if signedIn() && request.auth.uid == userId;
      }

      match /blockedBy/{blockerId} {
        allow read: if signedIn() && (
          request.auth.uid == userId ||
          request.auth.uid == blockerId
        );
        allow create: if signedIn() &&
          request.auth.uid == blockerId &&
          request.resource.data.blockerId == request.auth.uid;
        allow delete: if signedIn() && request.auth.uid == blockerId;
        allow update: if false;
      }
    }

    match /connectionRequests/{requestId} {
      allow read: if signedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow create: if signedIn() &&
        requestId == request.auth.uid + '_' + request.resource.data.receiverId &&
        request.resource.data.senderId == request.auth.uid &&
        request.resource.data.receiverId != request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if signedIn() &&
        resource.data.receiverId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status in ['accepted', 'rejected'];
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if signedIn() &&
        request.auth.uid in request.resource.data.participantIds &&
        (
          request.resource.data.type != 'direct' ||
          (
            request.resource.data.participantIds.size() == 2 &&
            (
              (request.resource.data.participantIds[0] == request.auth.uid && connectedTo(request.resource.data.participantIds[1])) ||
              (request.resource.data.participantIds[1] == request.auth.uid && connectedTo(request.resource.data.participantIds[0]))
            )
          )
        );
      allow update: if signedIn() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId) &&
          directChatCanMessage(chatId) &&
          request.resource.data.senderId == request.auth.uid;
        allow update: if isParticipant(chatId);
      }
    }

    match /statuses/{statusId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.expiresAt is timestamp;
      allow update: if signedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenBy']);
    }
  }
}
