{
  "rules": {
    "presence": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "typing": {
      "$chatId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "userIncoming": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$callId": {
          ".write": "auth != null && (
            auth.uid === $uid ||
            (!data.exists() && root.child('calls').child($callId).child('from').val() === auth.uid)
          )"
        }
      }
    },
    "calls": {
      "$callId": {
        ".read": "auth != null && (
          !data.exists() ||
          data.child('from').val() === auth.uid ||
          data.child('to').val() === auth.uid ||
          data.child('participants').child(auth.uid).exists()
        )",
        ".write": "auth != null && (
          (!data.exists() && newData.child('from').val() === auth.uid) ||
          (data.exists() && (
            data.child('from').val() === auth.uid ||
            data.child('to').val() === auth.uid ||
            data.child('participants').child(auth.uid).exists()
          ))
        )",
        "offer": {
          ".read": "auth != null && (
            root.child('calls').child($callId).child('from').val() === auth.uid ||
            root.child('calls').child($callId).child('to').val() === auth.uid ||
            root.child('calls').child($callId).child('participants').child(auth.uid).exists()
          )",
          ".write": "auth != null && (
            root.child('calls').child($callId).child('from').val() === auth.uid ||
            root.child('calls').child($callId).child('to').val() === auth.uid ||
            root.child('calls').child($callId).child('participants').child(auth.uid).exists()
          )"
        },
        "answer": {
          ".read": "auth != null && (
            root.child('calls').child($callId).child('from').val() === auth.uid ||
            root.child('calls').child($callId).child('to').val() === auth.uid ||
            root.child('calls').child($callId).child('participants').child(auth.uid).exists()
          )",
          ".write": "auth != null && (
            root.child('calls').child($callId).child('from').val() === auth.uid ||
            root.child('calls').child($callId).child('to').val() === auth.uid ||
            root.child('calls').child($callId).child('participants').child(auth.uid).exists()
          )"
        },
        "status": {
          ".read": "auth != null && (
            root.child('calls').child($callId).child('from').val() === auth.uid ||
            root.child('calls').child($callId).child('to').val() === auth.uid ||
            root.child('calls').child($callId).child('participants').child(auth.uid).exists()
          )",
          ".write": "auth != null && (
            root.child('calls').child($callId).child('from').val() === auth.uid ||
            root.child('calls').child($callId).child('to').val() === auth.uid ||
            root.child('calls').child($callId).child('participants').child(auth.uid).exists()
          )"
        },
        "endedAt": {
          ".write": "auth != null && (
            root.child('calls').child($callId).child('from').val() === auth.uid ||
            root.child('calls').child($callId).child('to').val() === auth.uid ||
            root.child('calls').child($callId).child('participants').child(auth.uid).exists()
          )"
        },
        "callType": {
          ".read": "auth != null && (
            !data.exists() ||
            root.child('calls').child($callId).child('from').val() === auth.uid ||
            root.child('calls').child($callId).child('to').val() === auth.uid ||
            root.child('calls').child($callId).child('participants').child(auth.uid).exists()
          )",
          ".write": "auth != null && (
            !data.exists() ||
            root.child('calls').child($callId).child('from').val() === auth.uid ||
            root.child('calls').child($callId).child('to').val() === auth.uid ||
            root.child('calls').child($callId).child('participants').child(auth.uid).exists()
          )"
        },
        "candidates": {
          ".read": "auth != null && (
            !root.child('calls').child($callId).exists() ||
            root.child('calls').child($callId).child('from').val() === auth.uid ||
            root.child('calls').child($callId).child('to').val() === auth.uid ||
            root.child('calls').child($callId).child('participants').child(auth.uid).exists()
          )",
          "$uid": {
            ".write": "auth != null && auth.uid === $uid && (
              !root.child('calls').child($callId).exists() ||
              root.child('calls').child($callId).child('from').val() === auth.uid ||
              root.child('calls').child($callId).child('to').val() === auth.uid ||
              root.child('calls').child($callId).child('participants').child(auth.uid).exists()
            )",
            "$candidateId": {
              ".write": "auth != null && auth.uid === $uid && (
                !root.child('calls').child($callId).exists() ||
                root.child('calls').child($callId).child('from').val() === auth.uid ||
                root.child('calls').child($callId).child('to').val() === auth.uid ||
                root.child('calls').child($callId).child('participants').child(auth.uid).exists()
              )"
            }
          }
        }
      }
    }
  }
}
